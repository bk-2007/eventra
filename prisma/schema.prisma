// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
  ORGANIZER
}

enum Category {
  TECHNICAL
  NON_TECHNICAL
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum CertificateType {
  PARTICIPATION
  WINNER
  RUNNER_UP
  VOLUNTEER
}

enum TeamMemberStatus {
  PENDING
  ACCEPTED
}

model User {
  id           String        @id
  email        String        @unique
  name         String
  college      String?
  phone        String?
  role         Role          @default(STUDENT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  registrations Registration[]
  certificates Certificate[]
  teamMembers  TeamMember[]
  events       Event[]       // Events organized by this user
}

model Event {
  id                   String          @id @default(uuid())
  title                String
  category             Category
  description          String
  bannerUrl            String?
  eventDate            DateTime
  venue                String
  registrationDeadline DateTime
  minTeamSize          Int             @default(1)
  maxTeamSize          Int             @default(1)
  prizePool            String
  organizerId          String
  organizer            User            @relation(fields: [organizerId], references: [id])
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  registrations        Registration[]
  certificates         Certificate[]
}

model Team {
  id          String        @id @default(uuid())
  name        String
  leaderId    String
  inviteCode  String        @unique
  createdAt   DateTime      @default(now())
  members     TeamMember[]
  registrations Registration[]
}

model TeamMember {
  id        String           @id @default(uuid())
  teamId    String
  team      Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    TeamMemberStatus @default(PENDING)
  joinedAt  DateTime         @default(now())

  @@unique([teamId, userId])
}

model Registration {
  id           String             @id @default(uuid())
  eventId      String
  event        Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId       String?            // null if registered as team
  user         User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId       String?            // null if registered as team
  team         Team?              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  status       RegistrationStatus @default(CONFIRMED)
  registeredAt DateTime           @default(now())

  @@unique([eventId, userId])
  @@unique([eventId, teamId])
}

model Certificate {
  id                String          @id @default(uuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId           String
  event             Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  certificateType   CertificateType @default(PARTICIPATION)
  downloadUrl       String
  verificationToken String          @unique
  issuedAt          DateTime        @default(now())
}
